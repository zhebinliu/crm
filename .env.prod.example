# Copy to .env and adjust values before running docker compose.
# docker-compose.prod.yml reads these.

# ── Database (Postgres) ────────────────────────────────────────────────────
POSTGRES_USER=tokenwave
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=tokenwave_crm

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 48
JWT_SECRET=change-me-generate-a-long-random-hex
JWT_REFRESH_SECRET=change-me-different-long-random-hex
JWT_EXPIRES_IN=7d

# ── CORS (allow the public domain the web talks from) ──────────────────────
API_CORS_ORIGINS=https://crm.tokenwave.cloud

# ── Public URL embedded into the web bundle at build time ──────────────────
NEXT_PUBLIC_API_URL=https://crm.tokenwave.cloud
