{
  "name": "tokenwave-crm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @tokenwave/db generate",
    "db:migrate": "pnpm --filter @tokenwave/db migrate",
    "db:push": "pnpm --filter @tokenwave/db push",
    "db:seed": "pnpm --filter @tokenwave/db seed",
    "db:studio": "pnpm --filter @tokenwave/db studio",
    "api:dev": "pnpm --filter @tokenwave/api start:dev",
    "web:dev": "pnpm --filter @tokenwave/web dev",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "graphql-type-json": "^0.3.2"
  }
}
